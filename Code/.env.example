# Copy to .env and adjust as needed.

# --- PostgreSQL ---
POSTGRES_USER=campus
POSTGRES_PASSWORD=campus
POSTGRES_DB=campus_sense
DATABASE_URL=postgresql://campus:campus@localhost:5433/campus_sense

# --- MQTT broker ---
MQTT_HOST=localhost
MQTT_PORT=1883

# --- API server ---
API_PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
# Campus timezone for evaluating the weekly class timetable (FR2).
CAMPUS_TZ=Asia/Jerusalem

# --- Decision engine ---
# Energy rule timers (from book §5.6.3)
EMPTY_MINUTES_BEFORE_OFF=10
SCHEDULE_LOOKAHEAD_MINUTES=15

# --- Edge unit ---
EDGE_FPS=2
PERSON_CONF_THRESHOLD=0.5
# Ignore spill detections below this confidence.
ANOMALY_CONF_THRESHOLD=0.7
